model Availability {
  id           String   @id @default(uuid())
  technicianId String   @unique
  workingDays  String[]
  startTime    String
  endTime      String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  technician   User     @relation(fields: [technicianId], references: [id], onDelete: Cascade)

  @@map("availabilities")
}
