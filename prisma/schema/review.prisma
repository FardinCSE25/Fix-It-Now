model Review {
    id String @id @default(uuid())

    customerId String
    customer   User   @relation("CustomerReviews", fields: [customerId], references: [id], onDelete: Cascade)

    technicianId String
    technician   User   @relation("TechnicianReviews", fields: [technicianId], references: [id], onDelete: Cascade)

    rating  Int
    comment String? @db.Text

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([customerId, technicianId])
    @@map("reviews")
}
